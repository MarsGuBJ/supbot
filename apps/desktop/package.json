{
  "name": "hbclient",
  "version": "0.1.5",
  "description": "Local single-user desktop agent.",
  "author": "HBClient contributors",
  "main": "dist/main/index.js",
  "bin": {
    "hbclient": "bin/hbclient.js"
  },
  "type": "commonjs",
  "files": [
    "dist",
    "bin",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:renderer && npm run build:main",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:renderer": "vite build",
    "build:main": "esbuild src/main/index.ts src/preload/index.ts --bundle --platform=node --target=node22 --format=cjs --outdir=dist --external:electron --external:@aws-sdk/client-s3",
    "test": "vitest run src/main/updateManager.test.ts src/renderer/lib/servstationFormat.test.ts src/renderer/servstationAutopilot.test.ts src/renderer/servstationCapabilities.test.ts src/renderer/servstationProjects.test.ts",
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"cross-env HBCLIENT_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "electron .",
    "prepare:default-skills": "node ../../scripts/prepare-bundled-skills.cjs",
    "dist:win": "npm run prepare:default-skills && electron-builder --win nsis",
    "dist:linux": "electron-builder --linux AppImage deb"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "@supbot/runtime": "file:../../packages/runtime",
    "@supbot/shared": "file:../../packages/shared",
    "antd": "^5.26.0",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.18.11"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "local.hbclient.desktop",
    "productName": "HBClient",
    "electronVersion": "42.4.1",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "copyright": "Copyright © 2026 HBClient contributors",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/default-data",
        "to": "default-data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "dist/main/index.js"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "http://101.227.67.76:8800/api/v1/hbclient/updates/stable/win32-x64",
        "useMultipleRangeRequest": false
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": false,
      "signtoolOptions": {
        "publisherName": "HBClient"
      }
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HBClient"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
