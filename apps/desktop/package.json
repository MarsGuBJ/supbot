{
  "name": "supbot",
  "version": "0.1.0",
  "description": "Local single-user desktop agent.",
  "main": "dist/main/index.js",
  "bin": {
    "supbot": "bin/supbot.js"
  },
  "type": "commonjs",
  "files": [
    "dist",
    "bin",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "esbuild src/main/index.ts src/preload/index.ts --bundle --platform=node --target=node22 --format=cjs --outdir=dist --external:electron",
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"cross-env SUPBOT_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "electron .",
    "dist:win": "electron-builder --win nsis",
    "dist:linux": "electron-builder --linux AppImage deb"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "@supbot/runtime": "file:../../packages/runtime",
    "@supbot/shared": "file:../../packages/shared",
    "antd": "^5.26.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "36.9.5",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.5",
    "vite": "^6.0.11"
  },
  "build": {
    "appId": "local.supbot.desktop",
    "productName": "Supbot",
    "electronVersion": "36.9.5",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/index.js"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    }
  }
}
